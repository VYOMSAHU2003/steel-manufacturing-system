# Oracle Database Configuration
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCL
ORACLE_USER=system
ORACLE_PASSWORD=your_password

# Application Settings
APP_SECRET_KEY=your_secret_key_here
DEBUG_MODE=false

# Low Stock Email Notification Settings
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=alerts@yourcompany.com
SMTP_USE_TLS=true
SMTP_TIMEOUT=20

# Optional: comma-separated management recipients.
# If empty, system uses active ADMIN, STORE_MANAGER and PRODUCTION_MANAGER user emails from database.
MANAGEMENT_EMAILS=
